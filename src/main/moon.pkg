import {
  "eanzhao/pi-moonbit/lib/ai" @ai,
  "eanzhao/pi-moonbit/lib/agent" @agent,
  "eanzhao/pi-moonbit/lib/coding_agent" @coding_agent,
  "moonbitlang/core/env" @env,
  "moonbitlang/core/json" @json,
  "moonbitlang/core/string" @string,
}

options(
  "is-main": true,
  targets: {
    "host_js.mbt": [ "js" ],
    "host_native.mbt": [ "native", "llvm" ],
    "host_wasm.mbt": [ "wasm", "wasm-gc" ],
  },
)
